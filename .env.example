OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=nvidia/nemotron-nano-9b-v2:free

# Data warehouse settings (local-first)
# Set ECOSIM_ENABLE_WAREHOUSE=1 to persist live simulation runs from backend/server.py
ECOSIM_ENABLE_WAREHOUSE=0
# Options: sqlite | postgres | timescale
ECOSIM_WAREHOUSE_BACKEND=sqlite
# SQLite path (used when backend=sqlite)
ECOSIM_SQLITE_PATH=backend/data/ecosim.db
# PostgreSQL / Timescale DSN (used when backend=postgres|timescale)
ECOSIM_WAREHOUSE_DSN=postgresql://ecosim:ecosim@localhost:5432/ecosim
# Batch size for tick metric writes
ECOSIM_TICK_BATCH_SIZE=50

# Labor matching rollout and unemployment guardrails
# fast = optimized matcher, legacy = original matcher
ECOSIM_LABOR_MATCH_MODE=fast
# Compare fast vs legacy outcomes periodically (debug only; adds overhead)
ECOSIM_COMPARE_LABOR_MATCH=0
ECOSIM_COMPARE_LABOR_MATCH_STRIDE=1
# Log labor diagnostics to backend logs
ECOSIM_LABOR_DIAGNOSTICS=0
ECOSIM_LABOR_DIAGNOSTICS_STRIDE=10
# De-risk unemployment behavior
ECOSIM_FORCE_UNEMPLOYED_SEARCH=1
ECOSIM_CLAMP_UNEMPLOYED_RESERVATION=1
ECOSIM_UNEMPLOYED_CLAMP_TICKS=8

# Optional for ecosim_chartjs experiments
CUBE_API_URL=https://your-cube-api-url.example.com/cubejs-api/v1
CUBE_API_TOKEN=your_cube_api_token_here
